# Opcionais (descomente se usar)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# HERMES_WEBHOOK_URL=https://...
# PLANNER_WEBHOOK_URL=https://...
# WHATSAPP_API_TOKEN=...
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=...
# IMAP_PASSWORD=...

# W3.1 — Meta WhatsApp Cloud API (oficial). Credenciais e roteamento vivem em
# vectraclip.adapter_catalog (slug=meta-whatsapp) + agent_adapter_configs:
#   field_values_json: { access_token, phone_number_id, webhook_verify_token,
#                        app_secret, api_version, function_url, template_id, ... }
# Webhook resolve company_id por phone_number_id; HMAC X-Hub-Signature-256
# verificado com app_secret. Nenhuma var de WhatsApp vai pro .env (Regra Ouro #2).
# Apenas legado da v0 do meta_client.py (outbound text/template) ainda lê env —
# será migrado pra adapter config em PR futuro.
# META_WA_TOKEN=                # legado meta_client.py:_token() — migrar pra adapter config
# META_WA_PHONE_NUMBER_ID=      # idem
# META_WA_API_VERSION=v25.0     # idem

# Ring buffer cap pra history de connector_sessions. P6 documentado em
# src/services/connector_bus.py — migrar pra catalog quando system_settings existir.
# CONNECTOR_HISTORY_RING_SIZE=50
