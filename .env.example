# Opcionais (descomente se usar)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# HERMES_WEBHOOK_URL=https://...
# PLANNER_WEBHOOK_URL=https://...
# WHATSAPP_API_TOKEN=...
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=...
# IMAP_PASSWORD=...

# W3 — Navi (Evolution API/WhatsApp) connector. Fail-closed: webhook rejeita
# se NAVI_WEBHOOK_SECRET não estiver setado. Em dev use NAVI_WEBHOOK_SECRET=dev.
# NAVI_API_URL=https://evolution.your-host.com
# NAVI_API_KEY=...
# NAVI_INSTANCE=default
# NAVI_WEBHOOK_SECRET=

# Ring buffer cap pra history de connector_sessions. P6 documentado em
# src/services/connector_bus.py — migrar pra catalog quando system_settings existir.
# CONNECTOR_HISTORY_RING_SIZE=50
